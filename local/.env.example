# Required: absolute path to the kernel tree this service instance will test.
NIPA_KERNEL_TREE=/absolute/path/to/linux

# Optional overrides.
# NIPA_STATE_DIR is the parent state directory; the service keeps its harness
# data under ${NIPA_STATE_DIR}/vmksft-net/.
NIPA_STATE_DIR=./state
NIPA_PATCH_DIR=./patches
NIPA_WEB_PORT=8888
NIPA_PUBLIC_HOST=localhost
VMKSFT_MODE=committed
VMKSFT_BUILD_CLEAN=config-change
VMKSFT_THREADS=auto
VMKSFT_CPUS=auto
VMKSFT_MEMORY=auto
VMKSFT_INIT_PROMPT=#
