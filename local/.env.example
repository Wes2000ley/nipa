# Required: absolute path to the kernel tree this service instance will test.
NIPA_KERNEL_TREE=/absolute/path/to/linux

# Optional overrides.
# NIPA_STATE_DIR is the parent state directory; the service keeps its harness
# data under ${NIPA_STATE_DIR}/vmksft-net/.
NIPA_STATE_DIR=./state
NIPA_WEB_PORT=8888
NIPA_PUBLIC_HOST=localhost

# Optional: whitespace-separated kselftest TARGETS suite for queued jobs.
# The value is frozen into each job at submission time.
NIPA_VMKSFT_TARGETS="net net/packetdrill drivers/net/netdevsim"

# Optional: whitespace/comma separated test names to suppress from every queued
# job. Values are frozen into each job at submission time.
NIPA_VMKSFT_SKIP_TESTS=
