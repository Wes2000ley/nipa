#!/bin/bash
# SPDX-License-Identifier: GPL-2.0

set -euo pipefail

LOCAL_DIR="$(cd -P -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
readonly LOCAL_DIR
readonly COMPOSE_FILE="${LOCAL_DIR}/docker-compose.yml"
readonly COMPOSE_SERVICE="vmksft-service"
readonly CONTAINER_QUEUE="/workspace/local/bin/vmksft_queue.py"
readonly CONTAINER_PATCH_ROOT="/tmp/local-vmksft-uploaded-patches"
readonly CONTAINER_INJECT_ROOT="/tmp/local-vmksft-uploaded-files"
readonly CONTAINER_KERNEL_TREE="/workspace/kernel"

PREPARED_QUEUE_ARGS=()
STAGED_PATHS=()

usage() {
	cat <<'EOF'
Usage:
  vmksft committed [queue-options...]
  vmksft dirty [queue-options...]
  vmksft patches --patch-dir PATH [queue-options...]
  vmksft submit [queue-options...]
  vmksft list
  vmksft show [--follow] JOB_ID
  vmksft cancel JOB_ID

Examples:
  ./vmksft committed
  ./vmksft dirty --threads 4
  ./vmksft committed --tests 'net:tcp_fastopen_backup_key.sh'
  ./vmksft dirty --tests 'net/packetdrill:tcp_rcv_toobig.pkt'
  ./vmksft committed --inject-file /tmp/helper.sh /abs/kernel/tree/tools/testing/selftests/net/
  ./vmksft dirty --inject-file /tmp/a.c /abs/kernel/tree/net/core/a.c --inject-file /tmp/b.h /abs/kernel/tree/include/linux/b.h
  ./vmksft patches --patch-dir ~/series --fresh-cache
  ./vmksft patches --patch-dir ~/series --tests 'net:mptcp_connect.sh'
  ./vmksft patches --patch-dir ~/series --inject-file ./fix.c /abs/kernel/tree/net/core/fix.c
  ./vmksft list
  ./vmksft show --follow JOB_ID

Behavior:
  - The only supported runtime is the long-lived Docker Compose service.
  - Start it with `docker compose up -d vmksft-service` or the Compose systemd unit.
  - `patches` mode freezes the supplied patch directory at queue time.
  - `--inject-file SRC DEST` overlays SRC onto absolute DEST within the configured kernel tree.
  - Repeat `--inject-file` once per file you want to overlay.
  - If DEST ends with `/`, vmksft appends the source basename after normalizing the path.
  - `--tests` accepts whitespace/comma-separated selectors like `prog.sh` or `target:prog.sh`.
  - `show --follow` stays attached and exits when the job becomes complete, failed, or cancelled.
EOF
}

need_cmd() {
	command -v "$1" >/dev/null 2>&1 || {
		printf 'vmksft: missing dependency: %s\n' "$1" >&2
		exit 1
	}
}

compose_args() {
	if [[ -f "${LOCAL_DIR}/.env" ]]; then
		printf '%s\0' --env-file "${LOCAL_DIR}/.env"
	fi
	printf '%s\0' -f "${COMPOSE_FILE}"
}

run_compose() {
	local -a args=()
	local -a cmd=(docker compose)
	local stderr_file=""
	local rc=0
	local quoted_local_dir=""
	local quoted_cmd=""

	while IFS= read -r -d '' item; do
		args+=("${item}")
	done < <(compose_args)

	cmd+=("${args[@]}" "$@")
	stderr_file="$(mktemp)"
	if (
		cd "${LOCAL_DIR}"
		"${cmd[@]}"
	) 2>"${stderr_file}"; then
		rm -f "${stderr_file}"
		return 0
	fi
	rc=$?

	if grep -q "permission denied while trying to connect to the docker API" "${stderr_file}" &&
		command -v sg >/dev/null 2>&1 &&
		getent group docker >/dev/null 2>&1; then
		printf -v quoted_local_dir '%q' "${LOCAL_DIR}"
		printf -v quoted_cmd '%q ' "${cmd[@]}"
		rm -f "${stderr_file}"
		sg docker -c "cd ${quoted_local_dir} && ${quoted_cmd% }"
		return $?
	fi

	cat "${stderr_file}" >&2
	rm -f "${stderr_file}"
	return "${rc}"
}

ensure_service_running() {
	need_cmd docker
	[[ -f "${COMPOSE_FILE}" ]] || {
		printf 'vmksft: docker compose file not found: %s\n' "${COMPOSE_FILE}" >&2
		exit 1
	}

	if run_compose ps --status running --services 2>/dev/null | grep -qx "${COMPOSE_SERVICE}"; then
		return 0
	fi

	printf 'vmksft: vmksft-service is not running; start it with docker compose up -d vmksft-service\n' >&2
	exit 1
}

run_queue() {
	run_compose exec -T "${COMPOSE_SERVICE}" python3 "${CONTAINER_QUEUE}" "$@"
}

resolve_configured_kernel_tree() {
	python3 - "${LOCAL_DIR}" "${LOCAL_DIR}/vmksft" <<'PY'
import sys

from pathlib import Path

local_dir = Path(sys.argv[1])
script_path = sys.argv[2]
sys.path.insert(0, str(local_dir / "lib"))

from vmksft_service_lib import load_runtime_config

try:
    print(load_runtime_config(script_path).kernel_tree)
except Exception as exc:
    print(f"vmksft: {exc}", file=sys.stderr)
    raise SystemExit(1)
PY
}

normalize_inject_spec() {
	local source_input="$1"
	local destination_input="$2"
	local kernel_tree="$3"

	python3 - "${LOCAL_DIR}" "${PWD}" "${source_input}" "${destination_input}" "${kernel_tree}" \
		"${CONTAINER_KERNEL_TREE}" <<'PY'
import sys

from pathlib import Path

local_dir = Path(sys.argv[1])
base_dir = Path(sys.argv[2])
source_input = sys.argv[3]
destination_input = sys.argv[4]
kernel_tree = Path(sys.argv[5])
container_kernel_tree = Path(sys.argv[6])

sys.path.insert(0, str(local_dir / "lib"))

from vmksft_service_lib import normalize_inject_destination, resolve_inject_source_path

try:
    source_path = resolve_inject_source_path(source_input, base_dir)
    destination_path, relative_destination = normalize_inject_destination(
        destination_input,
        source_path.name,
        kernel_tree,
        base_dir,
    )
    print(source_path)
    print(container_kernel_tree / relative_destination)
except Exception as exc:
    print(f"vmksft: {exc}", file=sys.stderr)
    raise SystemExit(1)
PY
}

reject_unsupported_options() {
	local command="$1"
	shift

	for arg in "$@"; do
		case "${arg}" in
		--explain|-explain)
			printf 'vmksft: %s does not support --explain; only the long-lived Compose service workflow is supported\n' "${command}" >&2
			exit 2
			;;
		esac
	done
}

prepare_queue_submit_args() {
	local command="$1"
	shift

	local -a rewritten=()
	local -a inject_pairs=()
	local patch_dir=""
	local expect_patch_dir=0
	local expect_inject_source=0
	local expect_inject_destination=0
	local inject_source=""
	local kernel_tree=""

	PREPARED_QUEUE_ARGS=()
	STAGED_PATHS=()

	for arg in "$@"; do
		if (( expect_patch_dir == 1 )); then
			patch_dir="${arg}"
			expect_patch_dir=0
			continue
		fi
		if (( expect_inject_source == 1 )); then
			inject_source="${arg}"
			expect_inject_source=0
			expect_inject_destination=1
			continue
		fi
		if (( expect_inject_destination == 1 )); then
			inject_pairs+=("${inject_source}" "${arg}")
			inject_source=""
			expect_inject_destination=0
			continue
		fi

		case "${arg}" in
		--patch-dir)
			expect_patch_dir=1
			;;
		--patch-dir=*)
			patch_dir="${arg#*=}"
			;;
		--inject-file)
			expect_inject_source=1
			;;
		*)
			rewritten+=("${arg}")
			;;
		esac
	done

	if (( expect_patch_dir == 1 )); then
		printf 'vmksft: missing value for --patch-dir\n' >&2
		exit 2
	fi
	if (( expect_inject_source == 1 || expect_inject_destination == 1 )); then
		printf 'vmksft: --inject-file requires SRC DEST\n' >&2
		exit 2
	fi

	if [[ "${command}" == "patches" && -z "${patch_dir}" ]]; then
		printf 'vmksft: patches requires --patch-dir PATH\n' >&2
		exit 2
	fi
	if [[ "${command}" != "patches" && "${command}" != "submit" && -n "${patch_dir}" ]]; then
		printf 'vmksft: --patch-dir is only valid with patches mode\n' >&2
		exit 2
	fi

	if [[ -n "${patch_dir}" ]]; then
		need_cmd realpath
		need_cmd tar
		local patch_dir_input="${patch_dir}"
		patch_dir="$(realpath -e -- "${patch_dir_input}")" || {
			printf 'vmksft: patch directory not found: %s\n' "${patch_dir_input}" >&2
			exit 1
		}
		[[ -d "${patch_dir}" ]] || {
			printf 'vmksft: patch directory is not a directory: %s\n' "${patch_dir}" >&2
			exit 1
		}

		local patch_tag="patches-$(date -u +%Y%m%d-%H%M%S)-$$-${RANDOM}"
		local container_patch_dir="${CONTAINER_PATCH_ROOT}/${patch_tag}"

		STAGED_PATHS+=("${container_patch_dir}")
		run_compose exec -T "${COMPOSE_SERVICE}" mkdir -p "${CONTAINER_PATCH_ROOT}"
		run_compose exec -T "${COMPOSE_SERVICE}" rm -rf "${container_patch_dir}"
		run_compose exec -T "${COMPOSE_SERVICE}" mkdir -p "${container_patch_dir}"
		if ! tar -C "${patch_dir}" -cf - . | \
			run_compose exec -T "${COMPOSE_SERVICE}" tar -xf - -C "${container_patch_dir}"; then
			cleanup_staged_paths
			printf 'vmksft: failed to stage patch directory into docker backend\n' >&2
			exit 1
		fi

		patch_dir="${container_patch_dir}"
		rewritten+=(--patch-dir "${patch_dir}")
	fi

	if (( ${#inject_pairs[@]} > 0 )); then
		need_cmd python3
		need_cmd tar
		kernel_tree="$(resolve_configured_kernel_tree)" || exit 1
		[[ -d "${kernel_tree}" ]] || {
			printf 'vmksft: kernel tree not found: %s\n' "${kernel_tree}" >&2
			exit 1
		}

		local inject_tag="inject-$(date -u +%Y%m%d-%H%M%S)-$$-${RANDOM}"
		local container_inject_dir="${CONTAINER_INJECT_ROOT}/${inject_tag}"
		local idx=0
		local ordinal=0
		local source_path=""
		local container_destination=""
		local source_dir=""
		local source_name=""
		local staged_source_dir=""
		local normalized_output=""
		local -a normalized=()

		STAGED_PATHS+=("${container_inject_dir}")
		run_compose exec -T "${COMPOSE_SERVICE}" mkdir -p "${CONTAINER_INJECT_ROOT}"
		run_compose exec -T "${COMPOSE_SERVICE}" rm -rf "${container_inject_dir}"
		run_compose exec -T "${COMPOSE_SERVICE}" mkdir -p "${container_inject_dir}"

		while (( idx < ${#inject_pairs[@]} )); do
			normalized_output="$(
				normalize_inject_spec "${inject_pairs[idx]}" "${inject_pairs[idx + 1]}" "${kernel_tree}"
			)" || exit 1
			mapfile -t normalized <<<"${normalized_output}"
			source_path="${normalized[0]}"
			container_destination="${normalized[1]}"
			source_dir="$(dirname -- "${source_path}")"
			source_name="$(basename -- "${source_path}")"
			ordinal=$((ordinal + 1))
			printf -v staged_source_dir '%s/%04d' "${container_inject_dir}" "${ordinal}"

			run_compose exec -T "${COMPOSE_SERVICE}" mkdir -p "${staged_source_dir}"
			if ! tar -C "${source_dir}" -cf - -- "${source_name}" | \
				run_compose exec -T "${COMPOSE_SERVICE}" tar -xf - -C "${staged_source_dir}"; then
				cleanup_staged_paths
				printf 'vmksft: failed to stage injected file into docker backend\n' >&2
				exit 1
			fi

			rewritten+=(--inject-file "${staged_source_dir}/${source_name}" "${container_destination}")
			idx=$((idx + 2))
		done
	fi

	PREPARED_QUEUE_ARGS=("${rewritten[@]}")
}

cleanup_staged_paths() {
	local path=""
	local idx=0
	for (( idx=${#STAGED_PATHS[@]} - 1; idx >= 0; idx-- )); do
		path="${STAGED_PATHS[idx]}"
		run_compose exec -T "${COMPOSE_SERVICE}" rm -rf "${path}" >/dev/null 2>&1 || true
	done
	STAGED_PATHS=()
}

run_submit() {
	local command="$1"
	shift

	set +e
	if [[ -n "${command}" ]]; then
		run_queue submit --mode "${command}" "${PREPARED_QUEUE_ARGS[@]}"
	else
		run_queue submit "${PREPARED_QUEUE_ARGS[@]}"
	fi
	local rc=$?
	set -e

	cleanup_staged_paths
	return "${rc}"
}

main() {
	local command="${1:-}"
	trap cleanup_staged_paths EXIT

	case "${command}" in
	""|-h|--help|help)
		usage
		exit 0
		;;
	committed|dirty|patches)
		shift
		reject_unsupported_options "${command}" "$@"
		ensure_service_running
		prepare_queue_submit_args "${command}" "$@"
		run_submit "${command}"
		exit $?
		;;
	submit)
		shift
		reject_unsupported_options "${command}" "$@"
		ensure_service_running
		prepare_queue_submit_args "${command}" "$@"
		run_submit ""
		exit $?
		;;
	list)
		shift
		ensure_service_running
		run_queue list "$@"
		exit $?
		;;
	show|cancel)
		shift
		[[ $# -ge 1 ]] || {
			printf 'vmksft: %s requires a job id\n' "${command}" >&2
			exit 1
		}
		ensure_service_running
		run_queue "${command}" "$@"
		exit $?
		;;
	*)
		printf 'vmksft: unknown command: %s\n' "${command}" >&2
		usage >&2
		exit 1
		;;
	esac
}

main "$@"
